# ============================================================
# MyChair — root environment reference (template only)
# ============================================================
# Copy values into Backend/.env and Frontend/.env as needed.
# NEVER commit real secrets. Generate JWT secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# See also:
#   Backend/.env.example
#   Frontend/.env.example
# ============================================================

# ─── Backend (FastAPI / Render) ─────────────────────────────
ENV=development
PORT=8000

# MongoDB (MONGO_URL preferred; MONGODB_URI also works)
MONGO_URL=mongodb+srv://mychair2917_db_user:mychair2917_db_user@cluster0.h1u0km9.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=Mychair

# Redis (REDIS_URL preferred; REDIS_URI also works)
REDIS_URL=redis://localhost:6379/0

# JWT / auth
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_secret
REFRESH_SECRET_KEY=CHANGE_ME_generate_another_64_char_hex_secret

# Public URLs
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8082"]

# Bootstrap admin
SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_strong_password

# Email (Resend)
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=MyChair <noreply@yourdomain.com>

# ─── Frontend (Vite) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=MyChair

# ─── Render / Jenkins (optional deploy) ─────────────────────
# Deploy Hook URL from Render dashboard (treat as secret)
RENDER_DEPLOY_HOOK_URL=
RENDER_DEPLOY=false
RENDER_SERVICE_NAME=mychair-api
RENDER_API_URL=https://your-api.onrender.com
