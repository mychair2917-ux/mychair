PROJECT_NAME=Salon ERP SaaS
API_V1_STR=/api/v1

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on Render; "development" for local docker-compose.
ENV=development
PORT=8000

# Health endpoints (no config needed):
#   GET /health       → lightweight liveness (Render uses this)
#   GET /health/deep  → Mongo + Redis readiness (use after deploy)

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET is an alias for SECRET_KEY (either name works).
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_secret
REFRESH_SECRET_KEY=CHANGE_ME_generate_another_64_char_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Database (MongoDB Atlas) ─────────────────────────────────────────────────
# MONGO_URL is the preferred name; MONGODB_URI also works.
# URL-encode special chars in password: @ → %40, # → %23, $ → %24
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>&retryWrites=true&w=majority
MONGODB_DB_NAME=Mychair

# ─── Cache / Queue (Redis) ────────────────────────────────────────────────────
# REDIS_URL is the preferred name; REDIS_URI also works.
# Local docker-compose: redis://redis:6379/0
# Render: auto-wired from managed Redis service
REDIS_URL=redis://redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# FRONTEND_URL is auto-added to allowed origins. Override for extra origins if needed:
# BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# ─── System Bootstrap Admin ───────────────────────────────────────────────────
SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sender is built as: `{RESEND_FROM_NAME} <{RESEND_FROM_EMAIL}>`
# Domain must be verified in Resend (e.g. mychair.co.in).
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=support@mychair.co.in
RESEND_FROM_NAME=MyChair
FRONTEND_URL=http://localhost:5173

# ─── Invitation ───────────────────────────────────────────────────────────────
INVITATION_TOKEN_EXPIRE_HOURS=72

# ─── Public URL / Assets ──────────────────────────────────────────────────────
# Set to your Render API public URL in production.
BACKEND_PUBLIC_URL=https://your-api.onrender.com

PUBLIC_ASSET_DIR=public

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME
WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=CHANGE_ME
# Leave empty in production so messages go to the real customer phone.
WHATSAPP_TEST_RECIPIENT_PHONE=
# Production: set your approved appointment template name and mode=live
WHATSAPP_APPOINTMENT_TEMPLATE=hello_world
WHATSAPP_TEMPLATE_MODE=test
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_random_string
WHATSAPP_REVIEW_URL=https://your-review-url.com
