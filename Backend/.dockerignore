# Backend Docker build context — exclude everything not needed in the image
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Tests & CI
.pytest_cache/
tests/
.coverage
htmlcov/

# Secrets — never bake into image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Dev tooling
.vscode/
.idea/
*.sw?

# Docs & misc
docs/
README.md
k8s-deployment.yaml
*.md

# Uploads/public (mounted as volumes in prod)
uploads/
public/
