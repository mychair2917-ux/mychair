# ============================================================
# Root .gitignore — MyChair Monorepo
# ============================================================

# --- Secret / Environment files ---
.env
.env.*
!.env.example
!**/.env.example
# Allow documented docker env templates only
!Frontend/.env.docker
!Frontend/.env.example
!Backend/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
Backend/venv/
Backend/.venv/
env/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.cover

# --- Node / Frontend ---
node_modules/
Frontend/dist/
Frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Uploads / generated assets ---
Backend/uploads/
Backend/public/

# --- Docker ---
*.override.yml.local

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sw?
Thumbs.db

# --- Logs / CI artifacts ---
logs/
*.log
/tmp/render-deploy-response.txt

# --- Jenkins / local workspaces ---
.jenkins/
