# ============================================================
# Root .gitignore — MyChair monorepo
# ============================================================

# --- Secret / Environment files ---
.env
.env.*
!.env.example
!**/.env.example
!**/.env.uat.example
!**/.env.production.example

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
mychair-backend/venv/
mychair-backend/.venv/
env/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.cover

# --- Node / Frontend ---
node_modules/
mychair-frontend/dist/
mychair-frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Uploads / generated assets ---
mychair-backend/uploads/
mychair-backend/public/

# --- Docker ---
*.override.yml.local

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sw?
Thumbs.db

# --- Logs / CI artifacts ---
logs/
*.log

# --- Local Python env at repo root ---
/venv/
