# ============================================================
# Root .gitignore — Mychair Monorepo
# ============================================================

# --- Secret / Environment files ---
.env
.env.*
!.env.example
!**/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# --- Node / Frontend ---
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Uploads / generated assets ---
Backend/uploads/
Backend/public/

# --- Docker ---
*.override.yml.local

# --- Editor ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sw?

# --- Logs ---
logs/
*.log
