# ============================================================
# MyChair Backend — environment template
# Copy to `.env` and fill in values. Never commit real secrets.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
#
# Also see:
#   .env.uat.example
#   .env.production.example
# ============================================================

PROJECT_NAME=Salon ERP SaaS
API_V1_STR=/api/v1

# uat | production  (ENV is also accepted as a legacy alias)
ENVIRONMENT=uat
PORT=8000

# JWT_SECRET and SECRET_KEY are aliases (either works)
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_secret
REFRESH_SECRET_KEY=CHANGE_ME_generate_another_64_char_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# MONGO_URL and MONGODB_URI are aliases
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=Mychair

# REDIS_URL and REDIS_URI are aliases
REDIS_URI=redis://localhost:6379/0

BACKEND_CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_strong_password

RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=MyChair <noreply@yourdomain.com>
RESEND_TEST_EMAIL=test@yourdomain.com

INVITATION_TOKEN_EXPIRE_HOURS=72
PUBLIC_ASSET_DIR=public

WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TEST_RECIPIENT_PHONE=
WHATSAPP_APPOINTMENT_TEMPLATE=hello_world
WHATSAPP_TEMPLATE_MODE=test
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_random_string
WHATSAPP_REVIEW_URL=
