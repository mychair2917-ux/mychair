# ============================================================
# MyChair Backend — UAT (local) example
# Copy to `.env` for local / UAT work.
# ============================================================

ENVIRONMENT=uat
PORT=8000

JWT_SECRET=CHANGE_ME_uat_jwt_secret
REFRESH_SECRET_KEY=CHANGE_ME_uat_refresh_secret

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=Mychair

REDIS_URI=redis://localhost:6379/0

BACKEND_CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_strong_password

RESEND_API_KEY=
EMAIL_FROM=MyChair <noreply@yourdomain.com>
RESEND_TEST_EMAIL=

INVITATION_TOKEN_EXPIRE_HOURS=72
PUBLIC_ASSET_DIR=public
