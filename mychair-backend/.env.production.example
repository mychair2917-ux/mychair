# ============================================================
# MyChair Backend — PRODUCTION example
# Copy to `.env` only on the host / set these in Render.
# All values MUST be provided — no production secrets in git.
# ============================================================

ENVIRONMENT=production
PORT=8000

JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_secret
REFRESH_SECRET_KEY=CHANGE_ME_generate_another_64_char_hex_secret

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=Mychair

REDIS_URI=redis://<host>:<port>

BACKEND_CORS_ORIGINS=["https://your-frontend.example.com"]
FRONTEND_URL=https://your-frontend.example.com
BACKEND_PUBLIC_URL=https://your-api.example.com

SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=CHANGE_ME_strong_password

RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=MyChair <noreply@yourdomain.com>
RESEND_TEST_EMAIL=ops@yourdomain.com

INVITATION_TOKEN_EXPIRE_HOURS=72
PUBLIC_ASSET_DIR=public

WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TEST_RECIPIENT_PHONE=
WHATSAPP_APPOINTMENT_TEMPLATE=hello_world
WHATSAPP_TEMPLATE_MODE=production
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_random_string
WHATSAPP_REVIEW_URL=
